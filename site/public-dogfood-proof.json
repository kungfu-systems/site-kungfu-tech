{
  "schema": "kungfu.tech/public-dogfood-proof/v3",
  "projection": {
    "mode": "verified-parent-bridge",
    "fallback": "retained-copy",
    "claim": "kungfu.tech selects from the upstream append-only observation chain and does not independently collect or pin its metrics.",
    "bridge": {
      "page": "https://libkungfu.dev/dogfood/?projection=kungfu-tech",
      "timelineMessage": "kungfu.dogfood.timeline/v1",
      "timelineRequestMessage": "kungfu.dogfood.timeline.request/v1",
      "requestMessage": "kungfu.dogfood.snapshot.request/v1",
      "responseMessage": "kungfu.dogfood.snapshot.response/v1"
    }
  },
  "upstream": {
    "repository": "https://github.com/kungfu-systems/site-libkungfu-dev",
    "humanPage": "https://libkungfu.dev/dogfood/",
    "machineEvidence": "https://libkungfu.dev/dogfood-evidence.json",
    "immutablePattern": "https://libkungfu.dev/dogfood-evidence/snapshots/{snapshotId}.json"
  },
  "boundaries": [
    "pull-request-not-feature",
    "author-account-not-agent-actor",
    "review-search-not-approval"
  ]
}
